FROM node:20-alpine AS builder

WORKDIR /app

# ── 先复制 package.json，利用 Docker 层缓存 ──────────
# 只有 package.json 变化时才重新 npm install（最耗时步骤）
COPY package.json package-lock.json* ./
RUN npm install

# ── 再复制源码（代码变更不会触发 npm install） ─────────
# ui-text.json / officials.json 已在 frontend/src/data/，无需跨目录引用
COPY . .

# ── Vite 构建 ─────────────────────────────────────────
RUN npm run build

# 产物在 /app/dist
